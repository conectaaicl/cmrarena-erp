generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  domain       String?  @unique
  logoUrl      String?
  primaryColor String   @default("#0f172a")
  taxRate      Decimal  @default(19) @db.Decimal(5, 2)
  isActive     Boolean  @default(true)
  planTier     PlanTier @default(STARTER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  clients       Client[]
  products      Product[]
  quotations    Quotation[]
  sales         Sale[]
  dtes          DTE[]
  siiConfig     SIIConfig?
  auditLogs     AuditLog[]
  notifications Notification[]
  files         File[]
  seoSite       SeoSite?
  tasks         Task[]

  @@index([slug])
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(SALES)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotations Quotation[]
  sales      Sale[]
  auditLogs  AuditLog[]
  tasks      Task[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES
  INVENTORY
  ACCOUNTANT
}

// ─────────────────────────────────────────
// CRM: CLIENTS
// ─────────────────────────────────────────

model Client {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  rut         String
  rutClean    String
  email       String?
  phone       String?
  address     String?
  commune     String?
  city        String?
  giro        String?
  website     String?
  contactName String?
  status      ClientStatus @default(NUEVO)
  notes       String?
  tags        String[]
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotations Quotation[]
  sales      Sale[]
  dtes       DTE[]
  tasks      Task[]

  @@unique([tenantId, rutClean])
  @@index([tenantId])
  @@index([tenantId, status])
}

enum ClientStatus {
  NUEVO
  CONTACTADO
  COTIZACION_ENVIADA
  SEGUIMIENTO
  APROBADO
  VENTA_CERRADA
  PERDIDO
}

// ─────────────────────────────────────────
// INVENTORY: PRODUCTS
// ─────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  category    String
  cost        Decimal  @default(0) @db.Decimal(12, 2)
  price       Decimal  @default(0) @db.Decimal(12, 2)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  unit        String   @default("un.")
  isActive    Boolean  @default(true)
  imageUrl    String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotationItems QuotationItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String
  productId   String
  type        StockMovementType
  quantity    Int
  reason      String?
  referenceId String?
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
}

enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
  DEVOLUCION
}

// ─────────────────────────────────────────
// QUOTATIONS
// ─────────────────────────────────────────

model Quotation {
  id          String          @id @default(cuid())
  tenantId    String
  number      Int
  clientId    String
  createdById String
  date        DateTime        @default(now())
  validUntil  DateTime?
  subtotal         Decimal         @db.Decimal(12, 2)
  taxAmount        Decimal         @db.Decimal(12, 2)
  installationCost Decimal         @default(0) @db.Decimal(12, 2)
  total            Decimal         @db.Decimal(12, 2)
  taxRate          Decimal         @default(19) @db.Decimal(5, 2)
  notes       String?
  pdfUrl      String?
  status      QuotationStatus @default(BORRADOR)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client          @relation(fields: [clientId], references: [id])
  createdBy User            @relation(fields: [createdById], references: [id])
  items     QuotationItem[]
  sales     Sale[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, clientId])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String
  description String?
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  width       Decimal? @db.Decimal(8, 2)
  height      Decimal? @db.Decimal(8, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

enum QuotationStatus {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
  VENCIDA
}

// ─────────────────────────────────────────
// SALES
// ─────────────────────────────────────────

model Sale {
  id            String        @id @default(cuid())
  tenantId      String
  number        Int
  clientId      String
  quotationId   String?
  createdById   String
  date          DateTime      @default(now())
  subtotal      Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  taxRate       Decimal       @default(19) @db.Decimal(5, 2)
  paymentMethod PaymentMethod @default(TRANSFERENCIA)
  paymentStatus PaymentStatus @default(PENDIENTE)
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id])
  quotation Quotation? @relation(fields: [quotationId], references: [id])
  createdBy User       @relation(fields: [createdById], references: [id])
  items     SaleItem[]
  dtes      DTE[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, date])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  description String?
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  subtotal    Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  DEBITO
  CREDITO
  CHEQUE
}

enum PaymentStatus {
  PAGADO
  PARCIAL
  PENDIENTE
}

// ─────────────────────────────────────────
// SII CHILE: DTEs
// ─────────────────────────────────────────

model SIIConfig {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  rutEmpresa       String
  razonSocial      String?
  giroComercial    String?
  direccion        String?
  comuna           String?
  environment      SIIEnv   @default(CERTIFICACION)
  resolutionNumber String?
  resolutionDate   DateTime?
  certFileUrl      String?
  certPasswordEnc  String?
  certExpiresAt    DateTime?
  lastBoletaFolio  Int      @default(0)
  lastFacturaFolio Int      @default(0)
  lastNCreditoFolio Int     @default(0)
  lastNDebitoFolio  Int     @default(0)
  isConfigured     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cafs   CAF[]
}

model CAF {
  id           String    @id @default(cuid())
  siiConfigId  String
  dteType      DTEType
  fromFolio    Int
  toFolio      Int
  currentFolio Int
  xmlContent   String    @db.Text
  issuedAt     DateTime
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  siiConfig SIIConfig @relation(fields: [siiConfigId], references: [id])

  @@index([siiConfigId, dteType])
}

model DTE {
  id          String    @id @default(cuid())
  tenantId    String
  saleId      String
  clientId    String
  type        DTEType
  folio       Int
  date        DateTime  @default(now())
  amount      Decimal   @db.Decimal(12, 2)
  taxAmount   Decimal   @db.Decimal(12, 2)
  netAmount   Decimal   @db.Decimal(12, 2)
  status      DTEStatus @default(PENDIENTE)
  trackId     String?
  xmlContent  String?   @db.Text
  pdfUrl      String?
  siiResponse Json?
  retryCount  Int       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale   @relation(fields: [saleId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@unique([tenantId, type, folio])
  @@index([tenantId])
  @@index([tenantId, status])
}

enum DTEType {
  BOLETA_ELECTRONICA
  FACTURA_ELECTRONICA
  NOTA_DE_CREDITO
  NOTA_DE_DEBITO
}

enum DTEStatus {
  PENDIENTE
  ENVIADO_SII
  ACEPTADO_SII
  RECHAZADO_SII
  ANULADO
}

enum SIIEnv {
  CERTIFICACION
  PRODUCCION
}

// ─────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entity])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String?
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  payload   Json?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
}

enum NotificationType {
  STOCK_CRITICO
  COTIZACION_APROBADA
  DTE_RECHAZADO
  NUEVO_CLIENTE
  PAGO_RECIBIDO
  CERTIFICADO_VENCIMIENTO
  GENERAL
}

// ─────────────────────────────────────────
// FILE STORAGE
// ─────────────────────────────────────────

model File {
  id         String      @id @default(cuid())
  tenantId   String
  name       String
  mimeType   String
  sizeBytes  Int
  storageKey String
  url        String
  purpose    FilePurpose
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, purpose])
}

enum FilePurpose {
  LOGO
  SII_CERTIFICATE
  QUOTATION_PDF
  DTE_PDF
  DTE_XML
  EXPORT
}

// ─────────────────────────────────────────
// SEO INTELLIGENCE
// ─────────────────────────────────────────

model SeoSite {
  id           String       @id @default(cuid())
  tenantId     String       @unique
  siteUrl      String
  googleToken  Json?
  lastSync     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keywords SeoKeyword[]
}

// ─────────────────────────────────────────
// TASKS / SEGUIMIENTO
// ─────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  clientId    String?
  createdById String
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus   @default(PENDIENTE)
  priority    TaskPriority @default(MEDIA)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client? @relation(fields: [clientId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum TaskPriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

model SeoKeyword {
  id          String   @id @default(cuid())
  siteId      String
  query       String
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  dateRange   String
  createdAt   DateTime @default(now())

  site SeoSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, query, dateRange])
  @@index([siteId, dateRange])
  @@index([siteId, position])
}
